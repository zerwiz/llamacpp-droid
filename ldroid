case "${1:-help}" in
  install)
    exec "$ROOT/install.sh"
    ;;
  update)
    exec "$ROOT/update.sh"
    ;;
  start|app)
    exec "$ROOT/start.sh"
    ;;
  stop)
    exec "$ROOT/stop.sh"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
