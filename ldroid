#!/usr/bin/env bash
# ldroid — CLI for llamacpp droid. Folder-agnostic; run from repo root or via PATH.
ROOT="$(cd "$(dirname "$0")" && pwd)"

show_banner() { [ -f "$ROOT/banner.txt" ] && cat "$ROOT/banner.txt" && echo; }

usage() {
  show_banner
  cat << 'EOF'
ldroid — Run and manage llamacpp droid (Electron app for llama.cpp Docker containers)

Usage:
  ldroid install [1|2|--system|--local]
                 Install app. At run time you can choose:
                   1 or --system  /opt/llamacpp-droid (system-wide, sudo)
                   2 or --local   This folder (user-only, no sudo)
                 Or run without args to be prompted.
  ldroid update     Pull latest code (if git) and refresh deps + launcher
  ldroid start      Start the app (background)
  ldroid stop       Stop the running app
  ldroid app        Same as start
  ldroid uninstall  Remove /opt install, desktop entry, and ldroid command (use -y to skip confirm)
  ldroid help       Show this help

Examples:
  ldroid install && ldroid start
  ldroid install 2
  ldroid install --local
  ldroid update
  ldroid uninstall --yes
EOF
}

case "${1:-help}" in
  install)
    exec "$ROOT/install.sh" "$2"
    ;;
  update)
    exec "$ROOT/update.sh"
    ;;
  start|app)
    exec "$ROOT/start.sh"
    ;;
  stop)
    exec "$ROOT/stop.sh"
    ;;
  uninstall)
    exec "$ROOT/uninstall.sh" "$2"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
